---
interface Props {
  title: string;
  subtitle?: string;
  tags?: string[];
  href?: string;

  // NEW: optional video preview
  previewVideo?: {
    src: string; // e.g. "/media/previews/clever-ball-menu.mp4"
    poster?: string; // optional poster image
    aspect?: "16/10" | "16/9" | "1/1";
  };
}

const { title, subtitle, tags = [], href = "#", previewVideo } = Astro.props as Props;

const aspectClass =
  previewVideo?.aspect === "16/9"
    ? "aspect-[16/9]"
    : previewVideo?.aspect === "1/1"
    ? "aspect-square"
    : "aspect-[16/10]";
---

<a
  href={href}
  class="group block rounded-2xl border border-white/10 bg-white/5 p-5 transition hover:border-white/20 hover:bg-white/[0.07]"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-semibold text-white">
        {title}
      </h3>

      {subtitle && (
        <p class="mt-1 text-sm text-white/70">
          {subtitle}
        </p>
      )}
    </div>

    <span
      class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70 transition group-hover:text-white/90"
    >
      View
    </span>
  </div>

  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((t) => (
        <span
          data-tag={t}
          class="rounded-full border border-white/10 bg-black/20 px-2.5 py-1 text-xs text-white/60"
        >
          {t}
        </span>
      ))}
    </div>
  )}

  {previewVideo && (
    <div class={`mt-5 overflow-hidden rounded-xl border border-white/10 bg-black/30 ${aspectClass}`}>
      <video
        class="h-full w-full object-cover"
        src={previewVideo.src}
        poster={previewVideo.poster}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      />
    </div>
  )}
</a>