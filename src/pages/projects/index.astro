---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const projects = [
  {
    title: "Clever Ball",
    subtitle: "Physics-based mobile game · 60+ levels · save + achievements · itch alpha",
    tags: ["Unity", "C#", "Physics", "Systems", "UI"],
    href: "/projects/clever-ball",
  },
  {
    title: "Mine Escape Quest",
    subtitle: "Team project at SDSU · endless loop + spawning systems",
    tags: ["Unity", "C#", "Team", "Gameplay"],
    href: "/projects/mine-escape-quest",
  },
  {
    title: "FS Project",
    subtitle: "Dialogue system + controller prototype",
    tags: ["Unity", "C#", "Dialogue", "State Machines"],
    href: "/projects/fs-project",
  },
  {
    title: "Faster Hunter",
    subtitle: "Multiplayer reaction-based Game",
    tags: ["Unity", "C#", "Multiplayer"],
    href: "/projects/faster-hunter",
  },
];
---
<BaseLayout title="Projects · Jaime Sanz Villalba">
  <h1 class="mt-4 text-3xl font-semibold tracking-[-0.02em] text-white md:text-6xl lg:text-7xl">
  <p class="mt-2 max-w-2xl text-sm text-white/70">
    Playable demos and engineering breakdowns focused on gameplay systems, real-time architecture, and iteration speed.
  </p>

  <div class="mt-6 grid gap-4 md:grid-cols-2">
    {projects.map((p) => <ProjectCard {...p} />)}
  </div>
</BaseLayout>