---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectTemplate from "../../components/ProjectTemplate.astro";

const project = {
  title: "Clever Ball",
  tagline:
    "A physics-driven mobile puzzle game focused on readable chaos, tight control, and fast ‘one more try’ mastery.",
  roleLine: "Solo project · Gameplay + Systems",
  statusLine: "In development · Public alpha available",
  chips: ["Mobile", "Unity", "C#", "Physics", "60+ levels", "Save/Progression"],
  primaryCta: { label: "Play Alpha (itch.io)", href: "https://riarugames.itch.io/clever-ball" },
  secondaryCta: { label: "Contact", href: "/contact" },
  media: { type: "video" as const, src: "/media/clever-ball/menu-loop.mp4", alt: "Clever Ball gameplay" },
};
---

<BaseLayout title="Clever Ball · Jaime Sanz Villalba">
  <ProjectTemplate {...project}>

    <!-- WHAT IT IS -->
    <section slot="overview" class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold text-white">What it is</h2>
      <p class="mt-3 text-sm text-white/70">
        Clever Ball is a level-based physics puzzle where the player uses momentum, timing, and environmental interactions
        to reach a goal with minimal friction. The focus is mobile-first clarity: short sessions, readable outcomes, fast
        retries, and a strong sense of mastery.
      </p>

      <ul class="mt-4 space-y-2 text-sm text-white/70">
        <li>• Short levels designed around a clear mechanic twist.</li>
        <li>• Fast failure, instant restart, visible cause/effect.</li>
        <li>• Difficulty pacing focused on learning and consistency.</li>
        <li>• Progression supported by save data, achievements and experience.</li>
      </ul>
    </section>


    <!-- GAMEPLAY OVERVIEW -->
    <section slot="gameplay" class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-xl font-semibold text-white">Gameplay overview</h2>
      <p class="mt-3 text-sm text-white/70">
        Goal: swipe to throw the ball, and get the star.
      </p>
      <p class="mt-3 text-sm text-white/70">
        
      </p>
      
        <div class="rounded-xl border border-white/10 bg-black/20 p-4">
          <h3 class="text-base font-semibold text-white">Easy to Learn</h3>
          <p class="mt-2 text-sm text-white/70">
            In the first level, there is with a quick tutorial (still fine-tuning it).
          </p>
          <p class="mt-2 text-sm text-white/70">
            The plan is to have this level as the first thing you see the first time you open the game.
          </p>

          <div
            class="mt-4 w-full max-w-[600px] mx-auto overflow-hidden rounded-lg border border-white/10 bg-black/30"
            style="aspect-ratio: 2868 / 1320;"
          >
            <video
              class="h-full w-full object-cover"
              src="/media/clever-ball/level-1.mp4"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          </div>
      
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div class="rounded-xl border border-white/10 bg-black/20 p-4">
            <h3 class="text-base font-semibold text-white">Variety of Mechanics</h3>
            <p class="mt-2 text-sm text-white/70">
              New ways to play emerge constantly.
            </p>

            <div class="mt-4 aspect-[2868/1320] overflow-hidden rounded-lg border border-white/10 bg-black/30">
              <video
                class="h-full w-full object-cover"
                src="/media/clever-ball/level-29.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
          </div>

          <div class="rounded-xl border border-white/10 bg-black/20 p-4">
            <h3 class="text-base font-semibold text-white">Complexity of Strategies</h3>
            <p class="mt-2 text-sm text-white/70">
              Levels can be complex, even with simple mechanics.
            </p>

            <div class="mt-4 aspect-[2868/1320] overflow-hidden rounded-lg border border-white/10 bg-black/30">
              <video
                class="h-full w-full object-cover"
                src="/media/clever-ball/level-53.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-white/10 bg-black/20 p-4">
          <h3 class="text-base font-semibold text-white">The Main Idea</h3>
          <p class="mt-2 text-sm text-white/70">
            You can use multiple balls in every level. This gives the game strategy and depth.
          </p>
          <div
            class="mt-4 w-full max-w-[600px] mx-auto overflow-hidden rounded-lg border border-white/10 bg-black/30"
            style="aspect-ratio: 2868 / 1320;"
          >
            <video
              class="h-full w-full object-cover"
              src="/media/clever-ball/level-6.mp4"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          </div>
        </div>
    </section>


    <!-- MENU AND UI -->
    <section slot="menu" class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-xl font-semibold text-white">Menu and UI overview</h2>
      <p class="mt-3 text-sm text-white/70">
        Designed to be simple, yet visually beautiful.
      </p>
      <p class="mt-3 text-sm text-white/70">
        
      </p>
      
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div class="rounded-xl border border-white/10 bg-black/20 p-4">
            <h3 class="text-base font-semibold text-white">Main Menu</h3>
            <p class="mt-2 text-sm text-white/70">
              Jump straight into the action.
            </p>

            <div class="mt-4 aspect-[2868/1320] overflow-hidden rounded-lg border border-white/10 bg-black/30">
              <video
                class="h-full w-full object-cover"
                src="/media/clever-ball/main-menu.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
          </div>

          <div class="rounded-xl border border-white/10 bg-black/20 p-4">
            <h3 class="text-base font-semibold text-white">Levels, Packs, and Progression</h3>
            <p class="mt-2 text-sm text-white/70">
              Have the best experience playing Clever Ball.
            </p>

            <div class="mt-4 aspect-[2868/1320] overflow-hidden rounded-lg border border-white/10 bg-black/30">
              <video
                class="h-full w-full object-cover"
                src="/media/clever-ball/levels-packs-progression.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
          </div>
        </div>
      
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div class="rounded-xl border border-white/10 bg-black/20 p-4">
            <h3 class="text-base font-semibold text-white">Achievements</h3>
            <p class="mt-2 text-sm text-white/70">
              Follow your path to Clever Ball mastery.
            </p>

            <div class="mt-4 aspect-[2868/1320] overflow-hidden rounded-lg border border-white/10 bg-black/30">
              <video
                class="h-full w-full object-cover"
                src="/media/clever-ball/achievements.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
          </div>

          <div class="rounded-xl border border-white/10 bg-black/20 p-4">
            <h3 class="text-base font-semibold text-white">Extra Clever</h3>
            <p class="mt-2 text-sm text-white/70">
              Prove your skills in our toughest challenges.
            </p>

            <div class="mt-4 aspect-[2868/1320] overflow-hidden rounded-lg border border-white/10 bg-black/30">
              <video
                class="h-full w-full object-cover"
                src="/media/clever-ball/extra-clever.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
          </div>
        </div>
    </section>

    <!-- PILLARS -->
    <section slot="pillars" class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold text-white">What makes it interesting</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-white/10 bg-black/20 p-4">
          <h3 class="text-sm font-semibold text-white">Physics that feels intentional</h3>
          <p class="mt-2 text-sm text-white/70">
            Outcomes are physics-based, but the player always has enough information to improve. Predictable and learnable
            is better than realisting.
          </p>
        </div>
        <div class="rounded-xl border border-white/10 bg-black/20 p-4">
          <h3 class="text-sm font-semibold text-white">Levels that teach through play</h3>
          <p class="mt-2 text-sm text-white/70">
            Each level introduces a concept, then escalates it with a constraint or twist. The goal is curiosity → attempt → adjustment.
          </p>
        </div>
        <div class="rounded-xl border border-white/10 bg-black/20 p-4">
          <h3 class="text-sm font-semibold text-white">Fast retries</h3>
          <p class="mt-2 text-sm text-white/70">
            Restart speed and feedback clarity keep the player in flow. Short sessions, low friction, high iteration.
          </p>
        </div>
        <div class="rounded-xl border border-white/10 bg-black/20 p-4">
          <h3 class="text-sm font-semibold text-white">Mobile-first readability</h3>
          <p class="mt-2 text-sm text-white/70">
            Clear silhouettes, minimal visual noise, and immediate goal states. The player should always understand “what happened”.
          </p>
        </div>
      </div>
    </section>

    <!-- AUDIENCE + TECH -->
    <section slot="audience" class="space-y-6">

      <!-- Top row (2 columns) -->
      <div class="grid gap-6 md:grid-cols-2">

        <!-- LEFT -->
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h2 class="text-lg font-semibold text-white">Target player & experience</h2>
          <ul class="mt-4 space-y-2 text-sm text-white/70">
            <li>• <span class="text-white/90">Audience:</span> players who enjoy skill-based puzzles and physics mastery.</li>
            <li>• <span class="text-white/90">Session length:</span> 30 seconds to ~3 minutes per level.</li>
            <li>• <span class="text-white/90">Goal feeling:</span> “I get it… one more try.”</li>
            <li>• <span class="text-white/90">Quality bar:</span> players can explain why they failed and what to try next.</li>
          </ul>
        </div>

        <!-- RIGHT -->
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h2 class="text-lg font-semibold text-white">Tech (high-level)</h2>
          <ul class="mt-4 space-y-2 text-sm text-white/70">
            <li>• Unity (C#), mobile-focused production constraints.</li>
            <li>• Core systems: save data, achievements, settings, progression system, and modular UI flow.</li>
            <li>• Commercial project (implementation details are intentionally not shared publicly).</li>
            <li>• Solid Software Engineering: Built a scalable, reusable structure to add content without increasing regression risk.</li>
          </ul>
        </div>
      </div>

    </section>
<section slot="iteration" class="rounded-2xl border border-white/10 bg-white/5 p-6">
  <h2 class="text-lg font-semibold text-white">
    New Challenges & Status
  </h2>

  <div class="mt-6 grid gap-6 md:grid-cols-2">

    <!-- BLOCK 3 -->
    <div class="rounded-xl border border-white/10 bg-black/20 p-5">
      <h3 class="text-base font-semibold text-white">
        Current status
      </h3>
      <ul class="mt-3 space-y-2 text-sm text-white/70">
        <li>• 60+ handcrafted levels implemented.</li>
        <li>• Over 10 unique mechanics designed and implemented, featuring button-based strategies, dynamic platforms, precision challenges, thematic levels... </li>
        <li>• Core progression systems complete.</li>
        <li>• Level pack system successfully implemented, to categorize levels and create a cohesive and rewarding player journey.</li>
        <li>• Achievement core system completed.</li>
        <li>• Design phase complete: All core features are fully conceptualized and ready for final implementation. </li>
        <li>• Public alpha available (with the first 30 levels and early-stage menus).</li>
      </ul>
    </div>

    <!-- BLOCK 4 (TEMPLATE) -->
    <div class="rounded-xl border border-white/10 bg-black/20 p-5">
      <h3 class="text-base font-semibold text-white">
        Next steps
      </h3>
      <ul class="mt-3 space-y-2 text-sm text-white/70">
        <li>• Finalize the progression system by implementing experience levels and a robust in-game economy.</li>
        <li>• Set the first level as the entry point for new save files to reduce time-to-play.</li>
        <li>• Fine-tune the tutorials to teach players the core mechanics effectively.</li>
        <li>• Refine the progression flow by reordering levels for better player retention.</li>
        <li>• Implement a dedicated shop featuring collectible ball skins and unique gadgets for specialized game modes.</li>
        <li>• Complete the gameplay suite with diverse challenges: Diamond Rush, Survival mode, and additional level packs.</li>
        <li>• Expand achievements and refine UI with custom icons and lock states for locked content.</li>
      </ul>
    </div>

  </div>
</section>

    <!-- LINKS -->
    <section slot="links" class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold text-white">Links</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href="https://riarugames.itch.io/clever-ball"
          target="_blank"
          rel="noreferrer"
          class="rounded-xl bg-white !text-black px-5 py-2.5 text-sm font-semibold shadow-2xl transition hover:bg-white/95 focus:outline-none focus:ring-4 focus:ring-cyan-300/30"
        >
          Play Alpha (itch.io)
        </a>
        <a href="/resume" class="rounded-xl border border-white/15 bg-white/5 px-4 py-2 text-sm text-white hover:bg-white/10">
          Resume
        </a>
        <a href="/contact" class="rounded-xl border border-white/15 bg-white/5 px-4 py-2 text-sm text-white hover:bg-white/10">
          Contact
        </a>
      </div>
    </section>

  </ProjectTemplate>
</BaseLayout>